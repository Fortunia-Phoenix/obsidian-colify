{
	"compilerOptions": {
		"baseUrl": ".",
		"inlineSourceMap": true,
		"inlineSources": true,
		"module": "ESNext",
		"target": "ES2020",
		"allowJs": false,
		"moduleResolution": "node",
		"importHelpers": true,
		"isolatedModules": true,
		"strict": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"forceConsistentCasingInFileNames": true,
		"lib": [
			"DOM",
			"ES2020"
		],
		"types": [
			"node"
		],
		"skipLibCheck": true
	},
	"include": [
		"src/**/*.ts"
	]
}
